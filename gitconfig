[user]
    name = qian-yu-db
    email = "q.yu@databricks.com"
[credential "https://github.com"]
    helper =
    helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !/opt/homebrew/bin/gh auth git-credential

[alias]
	s = status
	st = status -sb
	br = branch -vv
	a = add .
	aa = add -A
	c = commit
	cv = commit -v
	cob = checkout -b
	co = checkout
	di = diff
	dis = diff --stat
	diw = diff --color-words
	dc = diff --cached
	dcs = diff --cached --stat
	dcw = diff --cached --color-words
	dh = diff HEAD~
	grp = grep -C 1
	ff = merge --ff-only
	noff = merge --no-ff
	f = fetch --tags --prune
	fa = fetch --all --tags --prune
	stsh = stash --keep-index
	staash = stash --include-untracked
	update-submodules = submodule update --init --recursive
	upgrade-submodules = submodule update --init --remote

[diff]
	mnemonicPrefix = true
	wordRegex = "[^[:space:]]|([[:alnum:]]|UTF_8_GUARD)+"
	compactionHeuristic = true

[user]
	name = qian-yu-db
	email = q.yu@databricks.com

[color]
	ui = auto

[color "grep"]
	match = cyan bold
	selected = blue
	context = normal
	filename = magenta
	linenumber = green
	separator = yellow
	function = blue

[pretty]
	line = "%C(auto)%h %<|(60,trunc)%s %C(green)%ad%C(auto)%d"
	detail = "%C(auto)%h %s%n  %C(yellow)by %C(blue)%an %C(magenta)<%ae> [%G?] %C(green)%ad%n %C(auto)%d%n"

[merge]
	defaultToUpstream = true
	tool = vimdiff

[push]
	default = upstream

[grep]
	lineNumber = true
[core]
	editor = vim
	hooksPath = /Users/q.yu/.databricks/githooks
	autocrlf = input
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f

# When cloning EMU orgs via SSH, rewrite to use the EMU host alias
[url "git@github.com-emu:databricks-eng/"]
  insteadOf = git@github.com:databricks-eng/

[url "git@github.com-emu:databricks-field-eng/"]
  insteadOf = git@github.com:databricks-field-eng/

# When cloning EMU orgs via HTTPS, convert to SSH with the EMU alias
[url "git@github.com-emu:databricks-field-eng/"]
  insteadOf = https://github.com/databricks-field-eng/

[url "git@github.com-emu:databricks-eng/"]
  insteadOf = https://github.com/databricks-eng/

# gh CLI uses org-id@github.com: format for EMU organizations
[url "git@github.com-emu:"]
  insteadOf = org-140212977@github.com:

# Match HTTPS remote URLs for this org
[includeIf "hasconfig:remote.*.url:https://github.com/databricks-field-eng/**"]
    path = ~/.gitconfig-databricks-field-eng

# Match SSH remote URLs (after insteadOf rewrite) for this org
[includeIf "hasconfig:remote.*.url:git@github.com-emu:databricks-field-eng/**"]
    path = ~/.gitconfig-databricks-field-eng

# All other HTTPS GitHub URLs → SSH with default personal key
[url "git@github.com:"]
  insteadOf = https://github.com/

